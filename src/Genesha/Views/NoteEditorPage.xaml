<Page
    x:Class="Genesha.Views.NoteEditorPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Padding="16,10" ColumnSpacing="8"
              Background="{ThemeResource LayerFillColorDefaultBrush}"
              BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
              BorderThickness="0,0,0,1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="NoteNameText" Grid.Column="0" FontWeight="SemiBold" VerticalAlignment="Center" />
            <Button Grid.Column="1" Content="Export MD" Click="ExportMarkdownButton_Click" />
            <Button Grid.Column="2" Content="Export PDF" Click="ExportPdfButton_Click" Margin="8,0,0,0" />
            <TextBlock x:Name="ExportStatusText" Grid.Column="3" FontSize="12" Margin="12,0,0,0"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
            <TextBlock x:Name="SaveStatusText" Grid.Column="4" FontSize="12" Margin="12,0,0,0"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
        </Grid>

        <WebView2 x:Name="Editor" Grid.Row="1" />

        <!-- Off-screen; used only to render a clean, print-styled copy of the note for PDF export. -->
        <WebView2 x:Name="PrintView" Grid.Row="1" Width="1" Height="1" Opacity="0" IsHitTestVisible="False" />
    </Grid>
</Page>
