<Page
    x:Class="Genesha.Views.NoteEditorPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Padding="16,10" ColumnSpacing="8"
              Background="{ThemeResource LayerFillColorDefaultBrush}"
              BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
              BorderThickness="0,0,0,1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="NoteNameText" Grid.Column="0" FontWeight="SemiBold" VerticalAlignment="Center" />
            <TextBlock x:Name="SaveStatusText" Grid.Column="1" FontSize="12"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
        </Grid>

        <WebView2 x:Name="Editor" Grid.Row="1" />
    </Grid>
</Page>
