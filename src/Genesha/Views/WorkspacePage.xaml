<Page
    x:Class="Genesha.Views.WorkspacePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Genesha.ViewModels">
    <Grid Padding="24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Workspaces" FontSize="24" FontWeight="SemiBold" />

        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8">
            <Button Content="New Workspace" Click="NewWorkspaceButton_Click" />
            <Button Content="Open Existing Folder" Click="OpenExistingFolderButton_Click" />
        </StackPanel>

        <Grid Grid.Row="2">
            <TextBlock x:Name="EmptyStateText"
                       Text="No workspaces yet. Create one to get started."
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Visibility="Collapsed" />
            <ListView x:Name="WorkspacesList"
                      SelectionMode="None" IsItemClickEnabled="True"
                      ItemClick="WorkspacesList_ItemClick">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="vm:WorkspaceItemVm">
                        <Grid Padding="12,10" ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Spacing="2">
                                <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold" />
                                <TextBlock Text="{x:Bind Path}" FontSize="11"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{x:Bind LastOpenedText}" FontSize="11"
                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                            </StackPanel>
                            <Button Grid.Column="1" VerticalAlignment="Center" Background="Transparent" BorderThickness="0"
                                    Tag="{x:Bind}" Click="WorkspaceMenuButton_Click" ToolTipService.ToolTip="More options">
                                <FontIcon Glyph="&#xE712;" FontSize="14" />
                            </Button>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
    </Grid>
</Page>
