<Window
    x:Class="Genesha.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <NavigationView x:Name="NavView"
                    PaneDisplayMode="Left" OpenPaneLength="200"
                    IsSettingsVisible="False" IsBackButtonVisible="Collapsed"
                    IsPaneToggleButtonVisible="False"
                    ItemInvoked="NavView_ItemInvoked">
        <NavigationView.MenuItems>
            <NavigationViewItem x:Name="WorkspacesItem" Content="Workspaces" Tag="workspaces">
                <NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xE8B7;" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem x:Name="DashboardItem" Content="Dashboard" Tag="dashboard" Visibility="Collapsed">
                <NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xE80F;" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem x:Name="NotesItem" Content="Notes" Tag="notes" Visibility="Collapsed">
                <NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xE70B;" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem x:Name="NoteTypesItem" Content="Note Types" Tag="noteTypes" Visibility="Collapsed">
                <NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xE8FD;" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem x:Name="WhiteboardsItem" Content="Whiteboards" Tag="whiteboards" Visibility="Collapsed">
                <NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xE761;" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem x:Name="MermaidChartsItem" Content="Mermaid Charts" Tag="mermaidCharts" Visibility="Collapsed">
                <NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xE9F9;" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
        </NavigationView.MenuItems>

        <NavigationView.FooterMenuItems>
            <NavigationViewItem Content="User Manual" Tag="manual">
                <NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xE897;" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
        </NavigationView.FooterMenuItems>

        <Grid x:Name="RootGrid">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Padding="8,6" ColumnSpacing="8"
                  Background="{ThemeResource LayerFillColorDefaultBrush}"
                  BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                  BorderThickness="0,0,0,1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button x:Name="BackButton" Grid.Column="0" IsEnabled="False"
                        Click="BackButton_Click" ToolTipService.ToolTip="Back">
                    <FontIcon Glyph="&#xE72B;" FontSize="14" />
                </Button>
                <TextBlock Grid.Column="1" Text="Genesha"
                           VerticalAlignment="Center" FontWeight="SemiBold" Margin="8,0,0,0" />
                <TextBlock x:Name="CurrentWorkspaceText" Grid.Column="2"
                           VerticalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </Grid>

            <Frame x:Name="RootFrame" Grid.Row="1" Navigated="RootFrame_Navigated" />
        </Grid>
    </NavigationView>
</Window>
